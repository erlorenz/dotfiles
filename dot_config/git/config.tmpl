[user]
	name = {{ .name | quote }}
	email = {{ .email | quote }}

[alias]
	co = checkout
	br = branch
	ci = commit
	st = status
	ll = log --oneline

[init]
	defaultBranch = main

[pull]
	rebase = true

[push]
	autoSetupRemote = true

[diff]
	algorithm = histogram
	colorMoved = plain
	mnemonicPrefix = true

[commit]
	verbose = true

[column]
	ui = auto

[branch]
	sort = -committerdate

[tag]
	sort = -version:refname

[rerere]
	enabled = true
	autoupdate = true
